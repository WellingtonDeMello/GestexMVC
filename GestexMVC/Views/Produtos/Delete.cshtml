@model GestexMVC.Models.Produto

@{
    ViewData["Title"] = "Excluir Produto";
}

<h2>Excluir Produto</h2>

<p class="text-danger">Tem certeza que deseja excluir este produto?</p>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Nome</dt>
            <dd class="col-sm-7">@Model.Nome</dd>

            <dt class="col-sm-5">Preço de Venda</dt>
            <dd class="col-sm-7">@Model.PrecoVenda.ToString("C")</dd>

            <dt class="col-sm-5">Estoque</dt>
            <dd class="col-sm-7">@Model.QtdEstoque</dd>

            <dt class="col-sm-5">Ativo</dt>
            <dd class="col-sm-7">@(Model.Ativo ? "Sim" : "Não")</dd>
        </dl>
    </div>
</div>

<br />

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>