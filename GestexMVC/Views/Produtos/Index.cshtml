@model IEnumerable<GestexMVC.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<h2>Produtos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Novo Produto</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Imagem</th>
            <th>Nome</th>
            <th>Preço de Venda</th>
            <th>Categoria</th>
            <th>Estoque</th>
            <th>Estoque Mínimo</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagemUrl))
                    {
                        <img src="@item.ImagemUrl" alt="@item.Nome" style="height:50px; width:50px; object-fit:cover; border-radius:6px;" />
                    }
                    else
                    {
                        <span style="color:#aaa;">—</span>
                    }
                </td>
                <td>@item.Nome</td>
                <td>@item.PrecoVenda.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                <td>@(item.Categoria?.Nome ?? "—")</td>
                <td>
                    @if (item.QtdEstoque == 0)
                    {
                        <span class="badge bg-danger">Zerado</span>
                    }
                    else if (item.QtdEstoque <= item.EstoqueMinimo)
                    {
                        <span class="badge bg-warning text-dark">@item.QtdEstoque</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@item.QtdEstoque</span>
                    }
                </td>
                <td>@item.EstoqueMinimo</td>
                <td>@(item.Ativo ? "Sim" : "Não")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>