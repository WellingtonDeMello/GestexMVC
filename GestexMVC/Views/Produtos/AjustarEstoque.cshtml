@model GestexMVC.Models.Produto

@{
    ViewData["Title"] = "Ajustar Estoque";
}

<h2>Ajustar Estoque — @Model.Nome</h2>

<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-body">
                <p style="font-size:18px;">Estoque atual: <strong style="color:#1A3F6F; font-size:24px;">@Model.QtdEstoque</strong></p>
                <p style="font-size:16px; color:#555;">Estoque mínimo: @Model.EstoqueMinimo</p>
            </div>
        </div>

        <form asp-action="AjustarEstoque">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label" style="font-size:17px;">Quantidade a ajustar</label>
                <input type="number" name="quantidade" class="form-control" style="font-size:17px;"
                       placeholder="Ex: 10 para adicionar, -5 para remover" />
                <small class="text-muted">Use número positivo para adicionar e negativo para remover.</small>
            </div>

            <button type="submit" class="btn btn-primary">Confirmar Ajuste</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>