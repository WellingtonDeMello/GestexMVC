@model GestexMVC.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
}

<h2>Editar Produto</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="ImagemUrl" class="form-label"></label>
                <input asp-for="ImagemUrl" class="form-control" placeholder="Cole aqui a URL da imagem" />
                <span asp-validation-for="ImagemUrl" class="text-danger"></span>
                <div class="mt-2" id="previewImagem">
                    <img id="imgPreview" src="" alt="Preview" style="display:none; max-height:150px; border-radius:8px;" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descricao" class="form-label"></label>
                <input asp-for="Descricao" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label"></label>
                <select asp-for="CategoriaId" class="form-select">
                    <option value="">-- Sem categoria --</option>
                    @foreach (var c in ViewBag.Categorias)
                    {
                        <option value="@c.Id">@c.Nome</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="PrecoCusto" class="form-label"></label>
                <input asp-for="PrecoCusto" class="form-control" />
                <span asp-validation-for="PrecoCusto" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PrecoVenda" class="form-label"></label>
                <input asp-for="PrecoVenda" class="form-control" />
                <span asp-validation-for="PrecoVenda" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="QtdEstoque" class="form-label"></label>
                <input asp-for="QtdEstoque" class="form-control" />
                <span asp-validation-for="QtdEstoque" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EstoqueMinimo" class="form-label"></label>
                <input asp-for="EstoqueMinimo" class="form-control" />
                <span asp-validation-for="EstoqueMinimo" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Ativo" class="form-check-input" />
                <label asp-for="Ativo" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">Salvar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById("ImagemUrl").addEventListener("input", function () {
            var url = this.value;
            var img = document.getElementById("imgPreview");
            if (url) {
                img.src = url;
                img.style.display = "block";
            } else {
                img.style.display = "none";
            }
        });
    </script>
}