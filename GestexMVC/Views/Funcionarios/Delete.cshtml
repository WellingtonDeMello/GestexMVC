@model GestexMVC.Models.Funcionario

@{
    ViewData["Title"] = "Excluir Funcionário";
}

<h2>Excluir Funcionário</h2>

<p class="text-danger">Tem certeza que deseja excluir este funcionário?</p>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Nome</dt>
            <dd class="col-sm-7">@Model.Nome</dd>

            <dt class="col-sm-5">CPF</dt>
            <dd class="col-sm-7">@Model.CPF</dd>

            <dt class="col-sm-5">Cargo</dt>
            <dd class="col-sm-7">@Model.Cargo</dd>

            <dt class="col-sm-5">Data de Admissão</dt>
            <dd class="col-sm-7">@Model.DataAdmissao.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-5">Ativo</dt>
            <dd class="col-sm-7">@(Model.Ativo ? "Sim" : "Não")</dd>
        </dl>
    </div>
</div>

<br />

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>