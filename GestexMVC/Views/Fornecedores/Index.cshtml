@model IEnumerable<GestexMVC.Models.Fornecedor>

@{
    ViewData["Title"] = "Fornecedores";
}

<h2>Fornecedores</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Novo Fornecedor</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Razão Social</th>
            <th>CNPJ</th>
            <th>Contato</th>
            <th>Telefone</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RazaoSocial</td>
                <td>@item.CNPJ</td>
                <td>@item.NomeContato</td>
                <td>@item.Telefone</td>
                <td>@(item.Ativo ? "Sim" : "Não")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>