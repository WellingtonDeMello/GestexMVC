@model IEnumerable<GestexMVC.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<h2>Clientes</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Novo Cliente</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nome / Razão Social</th>
            <th>Tipo</th>
            <th>CPF / CNPJ</th>
            <th>Telefone</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nome</td>
                <td>
                    <span class="badge @(item.Tipo == "PF" ? "bg-primary" : "bg-warning text-dark")">
                        @item.Tipo
                    </span>
                </td>
                <td>@(item.Tipo == "PF" ? item.CPF : item.CNPJ)</td>
                <td>@item.Telefone</td>
                <td>@(item.Ativo ? "Sim" : "Não")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>