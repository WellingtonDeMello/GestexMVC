@model IEnumerable<GestexMVC.Models.Venda>

@{
    ViewData["Title"] = "Relatório de Vendas";
}

<h2>Relatório de Vendas</h2>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Relatorio" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Data Início</label>
                    <input type="date" name="dataInicio" class="form-control" value="@ViewBag.DataInicio" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Data Fim</label>
                    <input type="date" name="dataFim" class="form-control" value="@ViewBag.DataFim" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card text-center p-4" style="border-left: 6px solid #E87722; border-radius:12px;">
            <p style="font-size:16px; color:#555; margin-bottom:6px;">Total de Vendas</p>
            <h2 style="color:#E87722; font-size:48px; font-weight:700;">@ViewBag.TotalVendas</h2>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-center p-4" style="border-left: 6px solid #1A3F6F; border-radius:12px;">
            <p style="font-size:16px; color:#555; margin-bottom:6px;">Faturamento do Período</p>
            <h2 style="color:#1A3F6F; font-size:36px; font-weight:700;">@string.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C}", ViewBag.TotalPeriodo)</h2>
        </div>
    </div>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nº</th>
            <th>Data</th>
            <th>Cliente</th>
            <th>Funcionário</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.DataVenda.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(item.Cliente != null ? item.Cliente.Nome : "Balcão")</td>
                <td>@item.Funcionario?.Nome</td>
                <td>@item.Total.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
            </tr>
        }
    </tbody>
</table>

<button onclick="window.print()" class="btn btn-secondary mt-2">🖨️ Imprimir</button>
<a asp-action="Index" class="btn btn-primary mt-2">Voltar</a>