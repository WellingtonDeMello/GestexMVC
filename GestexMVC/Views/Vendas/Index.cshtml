@model IEnumerable<GestexMVC.Models.Venda>

@{
    ViewData["Title"] = "Vendas";
}

<h2>Vendas</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Nova Venda</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nº</th>
            <th>Data</th>
            <th>Cliente</th>
            <th>Funcionário</th>
            <th>Total</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.DataVenda.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(item.Cliente != null ? item.Cliente.Nome : "Balcão")</td>
                <td>@item.Funcionario?.Nome</td>
                <td>@item.Total.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                <td>
                    @if (item.Status == "Confirmada")
                    {
                        <span class="badge bg-success">Confirmada</span>
                    }
                    else if (item.Status == "Cancelada")
                    {
                        <span class="badge bg-danger">Cancelada</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Em Aberto</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Detalhes</a>
                    @if (item.Status == "Confirmada")
                    {
                        <form asp-action="Cancelar" asp-route-id="@item.Id" method="post" style="display:inline"
                              onsubmit="return confirm('Tem certeza que deseja cancelar esta venda?')">
                            <button type="submit" class="btn btn-sm btn-danger">Cancelar</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>