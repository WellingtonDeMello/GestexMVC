@{
    ViewData["Title"] = "Login";
    Layout = null; // Não usa o layout padrão — a tela de login tem visual próprio
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Gestex</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        /* Centraliza o card de login na tela com fundo azul */
        body {
            background-color: #1A3F6F;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        /* Card branco centralizado com sombra */
        .login-card {
            background: #fff;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
        }

        /* Logo e título do sistema */
        .login-logo {
            text-align: center;
            margin-bottom: 30px;
        }

            .login-logo h1 {
                color: #E87722;
                font-size: 36px;
                font-weight: 700;
                letter-spacing: 2px;
            }

            .login-logo span {
                color: #1A3F6F;
                background: #E87722;
                padding: 2px 8px;
                border-radius: 4px;
                margin-left: 4px;
                font-size: 28px;
            }

            .login-logo p {
                color: #555;
                font-size: 15px;
                margin-top: 6px;
            }

        .form-label {
            font-size: 16px;
            font-weight: 500;
            color: #1A3F6F;
        }

        .form-control {
            font-size: 17px;
            padding: 12px;
            border-radius: 8px;
        }

        /* Botão de login na cor laranja do Gestex */
        .btn-login {
            background-color: #E87722;
            border: none;
            color: #fff;
            font-size: 18px;
            padding: 12px;
            border-radius: 8px;
            width: 100%;
            font-weight: 600;
            margin-top: 8px;
        }

            .btn-login:hover {
                background-color: #cf6610;
                color: #fff;
            }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <h1>GESTEX <span>MVC</span></h1>
            <p>Sistema de Vendas e Gestão de Estoque</p>
        </div>

        @* Exibe a mensagem de erro caso login falhe *@
        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger" style="font-size:16px;">
                @ViewBag.Erro
            </div>
        }

        @* Formulário enviado via POST para o AuthController *@
        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label">Usuário</label>
                <input type="text" name="usuario" class="form-control" placeholder="Digite seu usuário" autofocus />
            </div>
            <div class="mb-3">
                <label class="form-label">Senha</label>
                <input type="password" name="senha" class="form-control" placeholder="Digite sua senha" />
            </div>
            <button type="submit" class="btn-login">Entrar</button>
        </form>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>